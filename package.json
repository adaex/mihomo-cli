{
  "name": "mihomo-cli",
  "version": "1.5.1",
  "description": "A terminal-based mihomo (Clash.Meta) client for macOS",
  "bin": {
    "mihomo-cli": "index.js",
    "mihomo": "index.js",
    "mmc": "index.js",
    "mh": "index.js"
  },
  "files": [
    "index.js",
    "src/**/*.js",
    "CHANGELOG.md"
  ],
  "scripts": {
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "keywords": [
    "mihomo",
    "clash",
    "clash-meta",
    "proxy",
    "vpn",
    "cli",
    "macos"
  ],
  "author": "Aex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adaex/mihomo-cli.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "compare-versions": "^6.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0"
  }
}
