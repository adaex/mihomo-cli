{
  "name": "mihomo-cli",
  "version": "2.10.0",
  "type": "module",
  "description": "A terminal-based mihomo (Clash.Meta) client for macOS",
  "bin": {
    "mihomo-cli": "dist/index.js",
    "mihomo": "dist/index.js",
    "mhm": "dist/index.js",
    "mh": "dist/index.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "check": "biome check .",
    "check:fix": "biome check --fix .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [
    "mihomo",
    "clash",
    "clash-meta",
    "proxy",
    "vpn",
    "cli",
    "macos"
  ],
  "author": "Aex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adaex/mihomo-cli.git"
  },
  "engines": {
    "node": ">=22.22.1"
  },
  "dependencies": {
    "compare-versions": "^6.1.0",
    "js-yaml": "^5.2.1"
  },
  "lint-staged": {
    "*.{ts,json,md}": "biome check --fix --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^22.20.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
